{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Herald Protocol",
  "logo": {
    "light": "/logo-light.png",
    "dark": "/logo-dark.png"
  },
  "fonts": {
    "heading": {
      "family": "JetBrains Mono"
    },
    "body": {
      "family": "Inter"
    }
  },
  "favicon": "/favicon.png",
  "colors": {
    "primary": "#5205ab",
    "light": "#c596fa",
    "dark": "#5c16c9"
  },
  "seo": {
    "metatags": {
      "canonical": "https://docs.heraldprotocol.xyz"
    }
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "heraldprotocol.xyz",
          "icon": "globe",
          "href": "https://heraldprotocol.xyz"
        },
        {
          "anchor": "GitHub",
          "icon": "github",
          "href": "https://github.com/heraldprotocol/protocol"
        },
        {
          "anchor": "X",
          "icon": "x-twitter",
          "href": "https://x.com/herald_protocol"
        }
      ]
    },
    "groups": [
      {
        "group": "Welcome",
        "pages": ["introduction", "faq"]
      },
      {
        "group": "x402",
        "pages": [
          "x402/overview",
          "x402/quickstart-for-sellers",
          "x402/quickstart-for-buyers",
          "x402/facilitator",
          "x402/supported-networks"
        ]
      },
      {
        "group": "MPP",
        "pages": [
          "mpp/overview",
          "mpp/quickstart-for-sellers",
          "mpp/quickstart-for-buyers",
          "mpp/architecture",
          "mpp/supported-networks"
        ]
      },
      {
        "group": "Router",
        "pages": ["router/overview", "router/quickstart-x402", "router/quickstart-mpp"]
      }
    ]
  },
  "search": {
    "prompt": "Search Herald Protocol docs..."
  }
}
