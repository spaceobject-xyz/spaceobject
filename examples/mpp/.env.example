# Server account private key (also used as the payment recipient)
MPP_SECRET_KEY=secret # generate: openssl rand -hex 32
SERVER_PRIVATE_KEY=0x...

# Client account private key (must be funded with USDC.e on 0G mainnet)
CLIENT_PRIVATE_KEY=0x...

# Server URL (defaults to http://localhost:3000)
SERVER_URL=http://localhost:3000
